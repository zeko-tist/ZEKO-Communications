# === API Keys ===
GEMINI_API_KEY=your-key-here

# === STT ===
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
SAMPLE_RATE=16000

# === LLM ===
GEMINI_MODEL=gemini-2.5-flash
LOCAL_LLM_MODEL_PATH=models/gemma-3-4b-it-Q4_K_M.gguf
LOCAL_LLM_GPU_LAYERS=-1
LOCAL_LLM_CTX_SIZE=2048

# === TTS — Online Primary (Sarvam AI) ===
SARVAM_API_KEY=your-sarvam-key-here
SARVAM_SPEAKER=shubh
SARVAM_LANGUAGE=ml-IN
SARVAM_MODEL=bulbul:v3

# === TTS — Online Fallback (Gemini) ===
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Pulcherrima

# === TTS — Offline (Kokoro) ===
KOKORO_LANG=en-us
KOKORO_VOICE=af_heart

# === VAD ===
VAD_THRESHOLD=0.3
VAD_SILENCE_MS=700
VAD_MAX_SECONDS=15

# === Connectivity ===
CONNECTIVITY_CHECK_URL=https://generativelanguage.googleapis.com
CONNECTIVITY_TTL_SECONDS=5
